{
  "manifest_version": 3,
  "name": "TH3 Wallet",
  "description": "TH3Chain browser wallet for TH3 addresses, balances, QR receive and sending TH3.",
  "version": "1.0.0",
  "action": {
    "default_title": "TH3 Wallet",
    "default_popup": "index.html?extension=chrome",
    "default_icon": {
      "16": "icons/favicon.png",
      "48": "icons/th3-logo.png",
      "128": "icons/th3-logo.png"
    }
  },
  "icons": {
    "16": "icons/favicon.png",
    "48": "icons/th3-logo.png",
    "128": "icons/th3-logo.png"
  },
  "host_permissions": [
    "https://api.th3chain.cloud/*",
    "https://explorer.th3chain.cloud/*"
  ],
  "permissions": [
    "clipboardWrite"
  ]
}
